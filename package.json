    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
